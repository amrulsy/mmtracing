// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTH & USER MANAGEMENT
// ==========================================

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  permissions Json?    // JSON array of permission strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  username  String   @unique @db.VarChar(50)
  email     String?  @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  roleId    Int
  status    String   @default("aktif") @db.VarChar(20) // aktif, non-aktif
  avatar    String?  @db.VarChar(255)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role          Role           @relation(fields: [roleId], references: [id])
  activityLogs  ActivityLog[]
  notifikasi    Notifikasi[]
  spkCreated    Spk[]          @relation("SpkCreator")

  @@map("users")
}

// ==========================================
// PELANGGAN & KENDARAAN
// ==========================================

model Pelanggan {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(150)
  phone     String   @db.VarChar(20)
  email     String?  @db.VarChar(100)
  address   String?  @db.Text
  type      String   @default("kendaraan") @db.VarChar(20) // kendaraan, bubut, both
  totalTrx  Decimal  @default(0) @db.Decimal(15, 2)
  lastVisit DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kendaraan     Kendaraan[]
  spk           Spk[]
  loyaltyPoints LoyaltyPoint[]
  loyaltyTierId Int?
  loyaltyTier   LoyaltyTier?   @relation(fields: [loyaltyTierId], references: [id])

  @@map("pelanggan")
}

model Kendaraan {
  id          Int      @id @default(autoincrement())
  pelangganId Int
  name        String   @db.VarChar(100) // e.g. Honda Vario 150
  plat        String   @db.VarChar(20)
  tahun       String?  @db.VarChar(4)
  warna       String?  @db.VarChar(30)
  noRangka    String?  @db.VarChar(50)
  noMesin     String?  @db.VarChar(50)
  odometer    Int?     // last known kilometer
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pelanggan Pelanggan  @relation(fields: [pelangganId], references: [id], onDelete: Cascade)
  spk       Spk[]
  inspeksi  Inspeksi[]

  @@map("kendaraan")
}

// ==========================================
// MEKANIK
// ==========================================

model Mekanik {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  spesialisasi String? @db.VarChar(100)
  status      String   @default("available") @db.VarChar(20) // available, busy, off
  rating      Decimal  @default(0) @db.Decimal(3, 1)
  totalSpk    Int      @default(0)
  avgTime     String?  @db.VarChar(20) // human-readable avg time
  initial     String?  @db.VarChar(5)
  color       String?  @db.VarChar(30) // CSS class for avatar color
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spk     Spk[]
  jadwal  Jadwal[]

  @@map("mekanik")
}

// ==========================================
// MASTER DATA: SPAREPART, JASA, SUPPLIER
// ==========================================

model KategoriSparepart {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  sparepart Sparepart[]

  @@map("kategori_sparepart")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(150)
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(100)
  address   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sparepart     Sparepart[]
  inventarisLog InventarisLog[]

  @@map("supplier")
}

model Sparepart {
  id          Int      @id @default(autoincrement())
  kode        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(150)
  merk        String?  @db.VarChar(50)
  kategoriId  Int?
  supplierId  Int?
  hargaBeli   Decimal  @default(0) @db.Decimal(12, 2)
  hargaJual   Decimal  @default(0) @db.Decimal(12, 2)
  stok        Int      @default(0)
  stokMinimum Int      @default(5)
  satuan      String   @default("pcs") @db.VarChar(20)
  lokasi      String?  @db.VarChar(50) // rak/gudang location
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kategori      KategoriSparepart? @relation(fields: [kategoriId], references: [id])
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  spkItems      SpkItem[]
  inventarisLog InventarisLog[]
  jasaBundles   JasaSparepart[]

  @@map("sparepart")
}

model Jasa {
  id          Int      @id @default(autoincrement())
  kode        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(150)
  kategori    String?  @db.VarChar(50)
  harga       Decimal  @default(0) @db.Decimal(12, 2)
  estimasiWaktu String? @db.VarChar(30) // e.g. "30 mnt", "2 jam"
  garansiHari Int      @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spkItems         SpkItem[]
  sparepartBundles JasaSparepart[]

  @@map("jasa")
}

model JasaSparepart {
  id          Int      @id @default(autoincrement())
  jasaId      Int
  sparepartId Int
  qtyDefault  Int      @default(1)

  jasa        Jasa      @relation(fields: [jasaId], references: [id], onDelete: Cascade)
  sparepart   Sparepart @relation(fields: [sparepartId], references: [id], onDelete: Cascade)

  @@unique([jasaId, sparepartId])
  @@map("jasa_sparepart")
}

// ==========================================
// SPK (Surat Perintah Kerja)
// ==========================================

model Spk {
  id           Int      @id @default(autoincrement())
  noSpk        String   @unique @db.VarChar(30)
  tanggal      DateTime @default(now())
  pelangganId  Int
  kendaraanId  Int?     // null for bubut lepas
  mekanikId    Int?
  createdById  Int
  mode         String   @default("rutin") @db.VarChar(20) // rutin, modifikasi, bubut
  status       String   @default("antri") @db.VarChar(20) // antri, dikerjakan, kendala, selesai, dibatalkan
  keluhan      String?  @db.Text
  // Modifikasi fields
  judulProyek  String?  @db.VarChar(200)
  spesifikasi  String?  @db.Text
  // Pricing
  totalHarga   Decimal  @default(0) @db.Decimal(15, 2)
  totalBayar   Decimal  @default(0) @db.Decimal(15, 2)
  minimumDp    Decimal  @default(0) @db.Decimal(15, 2)
  // Progress
  progress     Int      @default(0) // 0-100
  prioritas    String   @default("normal") @db.VarChar(20) // rendah, normal, tinggi, urgent
  catatan      String?  @db.Text
  estimasiSelesai DateTime? // ETA kapan SPK diperkirakan selesai
  diskon       Decimal  @default(0) @db.Decimal(12, 2) // Diskon nominal
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pelanggan     Pelanggan         @relation(fields: [pelangganId], references: [id])
  kendaraan     Kendaraan?        @relation(fields: [kendaraanId], references: [id])
  mekanik       Mekanik?          @relation(fields: [mekanikId], references: [id])
  createdBy     User              @relation("SpkCreator", fields: [createdById], references: [id])
  items         SpkItem[]
  stages        SpkStage[]
  photos        SpkPhoto[]
  pembayaran    Pembayaran[]
  garansi       Garansi[]
  jadwal        Jadwal[]
  approvalToken ApprovalToken[]

  @@map("spk")
}

model SpkItem {
  id          Int      @id @default(autoincrement())
  spkId       Int
  type        String   @db.VarChar(10) // jasa, sparepart
  sparepartId Int?
  jasaId      Int?
  nama        String   @db.VarChar(150)
  qty         Int      @default(1)
  hargaSatuan Decimal  @default(0) @db.Decimal(12, 2)
  subtotal    Decimal  @default(0) @db.Decimal(12, 2)
  status      String   @default("pending") @db.VarChar(20) // pending, done
  createdAt   DateTime @default(now())

  spk       Spk        @relation(fields: [spkId], references: [id], onDelete: Cascade)
  sparepart Sparepart? @relation(fields: [sparepartId], references: [id])
  jasa      Jasa?      @relation(fields: [jasaId], references: [id])

  @@map("spk_items")
}

model SpkStage {
  id          Int      @id @default(autoincrement())
  spkId       Int
  urutan      Int      @default(1)
  nama        String   @db.VarChar(150)
  estimasiBiaya Decimal @default(0) @db.Decimal(12, 2)
  durasiHari  Int      @default(1)
  status      String   @default("pending") @db.VarChar(20) // pending, in_progress, done
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  spk Spk @relation(fields: [spkId], references: [id], onDelete: Cascade)

  @@map("spk_stages")
}

model SpkPhoto {
  id        Int      @id @default(autoincrement())
  spkId     Int
  url       String   @db.VarChar(255)
  caption   String?  @db.VarChar(200)
  type      String   @default("progress") @db.VarChar(20) // before, progress, after, lampiran
  createdAt DateTime @default(now())

  spk Spk @relation(fields: [spkId], references: [id], onDelete: Cascade)

  @@map("spk_photos")
}

// ==========================================
// PEMBAYARAN
// ==========================================

model Pembayaran {
  id           Int      @id @default(autoincrement())
  noInvoice    String   @unique @db.VarChar(30)
  spkId        Int
  tanggal      DateTime @default(now())
  totalTagihan Decimal  @default(0) @db.Decimal(15, 2)
  totalBayar   Decimal  @default(0) @db.Decimal(15, 2)
  sisaBayar    Decimal  @default(0) @db.Decimal(15, 2)
  status       String   @default("belum_bayar") @db.VarChar(20) // belum_bayar, parsial, lunas
  jatuhTempo   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  spk    Spk                @relation(fields: [spkId], references: [id])
  detail PembayaranDetail[]

  @@map("pembayaran")
}

model PembayaranDetail {
  id           Int      @id @default(autoincrement())
  pembayaranId Int
  tanggal      DateTime @default(now())
  jumlah       Decimal  @db.Decimal(15, 2)
  metode       String   @db.VarChar(30) // cash, transfer_bca, transfer_mandiri, qris, dll
  keterangan   String?  @db.VarChar(200)
  buktiUrl     String?  @db.VarChar(255)
  createdAt    DateTime @default(now())

  pembayaran Pembayaran @relation(fields: [pembayaranId], references: [id], onDelete: Cascade)

  @@map("pembayaran_detail")
}

// ==========================================
// INVENTARIS
// ==========================================

model InventarisLog {
  id          Int      @id @default(autoincrement())
  sparepartId Int
  supplierId  Int?
  type        String   @db.VarChar(20) // masuk, keluar, opname, retur
  qty         Int
  hargaSatuan Decimal  @default(0) @db.Decimal(12, 2)
  totalHarga  Decimal  @default(0) @db.Decimal(12, 2)
  noPo        String?  @db.VarChar(30) // purchase order number
  keterangan  String?  @db.VarChar(200)
  createdBy   String?  @db.VarChar(50)
  createdAt   DateTime @default(now())

  sparepart Sparepart @relation(fields: [sparepartId], references: [id])
  supplier  Supplier? @relation(fields: [supplierId], references: [id])

  @@map("inventaris_log")
}

model StokOpname {
  id          Int      @id @default(autoincrement())
  tanggal     DateTime @default(now())
  status      String   @default("draft") @db.VarChar(20) // draft, selesai
  catatan     String?  @db.Text
  createdBy   String?  @db.VarChar(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items StokOpnameItem[]

  @@map("stok_opname")
}

model StokOpnameItem {
  id            Int    @id @default(autoincrement())
  stokOpnameId  Int
  sparepartId   Int
  stokSistem    Int
  stokFisik     Int
  selisih       Int
  keterangan    String? @db.VarChar(200)

  stokOpname StokOpname @relation(fields: [stokOpnameId], references: [id], onDelete: Cascade)

  @@map("stok_opname_items")
}

// ==========================================
// GARANSI
// ==========================================

model Garansi {
  id          Int      @id @default(autoincrement())
  spkId       Int
  itemName    String   @db.VarChar(150)
  type        String   @db.VarChar(20) // jasa, part, modif
  startDate   DateTime
  endDate     DateTime
  status      String   @default("aktif") @db.VarChar(20) // aktif, hampir, expired
  createdAt   DateTime @default(now())

  spk    Spk            @relation(fields: [spkId], references: [id])
  claims GaransiClaim[]

  @@map("garansi")
}

model GaransiClaim {
  id         Int      @id @default(autoincrement())
  garansiId  Int
  claimDate  DateTime @default(now())
  reason     String   @db.Text
  status     String   @default("diproses") @db.VarChar(20) // diproses, selesai, ditolak
  resolution String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  garansi Garansi @relation(fields: [garansiId], references: [id])

  @@map("garansi_claims")
}

// ==========================================
// JADWAL & BOOKING
// ==========================================

model Jadwal {
  id          Int      @id @default(autoincrement())
  spkId       Int?
  mekanikId   Int?
  tanggal     DateTime
  jamMulai    String   @db.VarChar(5) // HH:mm
  jamSelesai  String   @db.VarChar(5)
  namaBooking String   @db.VarChar(100)
  pekerjaan   String?  @db.VarChar(200)
  kategori    String   @default("servis") @db.VarChar(20) // servis, modifikasi, bubut, booking, fleet
  warna       String?  @db.VarChar(30) // CSS color class
  status      String   @default("dijadwalkan") @db.VarChar(20) // dijadwalkan, berlangsung, selesai, batal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spk     Spk?     @relation(fields: [spkId], references: [id])
  mekanik Mekanik? @relation(fields: [mekanikId], references: [id])

  @@map("jadwal")
}

// ==========================================
// PENGELUARAN OPERASIONAL
// ==========================================

model KategoriPengeluaran {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(50)

  pengeluaran Pengeluaran[]

  @@map("kategori_pengeluaran")
}

model Pengeluaran {
  id          Int      @id @default(autoincrement())
  kategoriId  Int
  tanggal     DateTime @default(now())
  deskripsi   String   @db.VarChar(200)
  jumlah      Decimal  @db.Decimal(12, 2)
  metode      String   @db.VarChar(30) // cash, transfer, auto-debit
  oleh        String?  @db.VarChar(50)
  buktiUrl    String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kategori KategoriPengeluaran @relation(fields: [kategoriId], references: [id])

  @@map("pengeluaran")
}

// ==========================================
// LOYALTY PROGRAM
// ==========================================

model LoyaltyTier {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(30) // Bronze, Silver, Gold
  minPoints   Int      @default(0)
  maxPoints   Int?
  benefits    String?  @db.Text
  createdAt   DateTime @default(now())

  pelanggan Pelanggan[]

  @@map("loyalty_tiers")
}

model LoyaltyPoint {
  id          Int      @id @default(autoincrement())
  pelangganId Int
  type        String   @db.VarChar(20) // earn, redeem
  points      Int
  description String?  @db.VarChar(200)
  refType     String?  @db.VarChar(30) // transaksi, referral, ulang_tahun, review, redeem
  refId       Int?     // reference ID (e.g. spk id, reward id)
  createdAt   DateTime @default(now())

  pelanggan Pelanggan @relation(fields: [pelangganId], references: [id])

  @@map("loyalty_points")
}

model LoyaltyReward {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150)
  pointsCost  Int
  stock       Int      @default(0)
  description String?  @db.VarChar(200)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("loyalty_rewards")
}

// ==========================================
// NOTIFIKASI
// ==========================================

model Notifikasi {
  id        Int      @id @default(autoincrement())
  userId    Int?
  type      String   @db.VarChar(20) // spk, pembayaran, monitoring, stok, sistem
  title     String   @db.VarChar(150)
  message   String   @db.Text
  link      String?  @db.VarChar(200)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("notifikasi")
}

// ==========================================
// INSPEKSI
// ==========================================

model Inspeksi {
  id          Int      @id @default(autoincrement())
  kendaraanId Int
  tanggal     DateTime @default(now())
  odometer    Int?
  catatan     String?  @db.Text
  items       Json?    // JSON array of inspection items
  result      String   @default("baik") @db.VarChar(20) // baik, perlu_perbaikan, kritis
  createdBy   String?  @db.VarChar(50)
  createdAt   DateTime @default(now())

  kendaraan Kendaraan @relation(fields: [kendaraanId], references: [id])

  @@map("inspeksi")
}

// ==========================================
// APPROVAL TOKENS
// ==========================================

model ApprovalToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(100)
  spkId     Int
  status    String   @default("pending") @db.VarChar(20) // pending, approved, rejected
  expiresAt DateTime
  respondedAt DateTime?
  createdAt DateTime @default(now())

  spk Spk @relation(fields: [spkId], references: [id])

  @@map("approval_tokens")
}

// ==========================================
// ACTIVITY LOG
// ==========================================

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String   @db.VarChar(50) // create, update, delete, login, logout, etc.
  module     String   @db.VarChar(30) // spk, pembayaran, inventaris, etc.
  targetId   Int?     // ID of the affected record
  targetName String?  @db.VarChar(150) // human-readable name
  detail     String?  @db.Text // JSON or text detail
  ipAddress  String?  @db.VarChar(50)
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// ==========================================
// SETTINGS (Key-Value)
// ==========================================

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text
  group String @default("general") @db.VarChar(30) // general, bengkel, whatsapp, notifikasi, tampilan

  @@map("settings")
}
